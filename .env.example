# LegalDesk — пример переменных окружения
# Скопируйте в .env и настройте под вашу среду

# URL Ollama API (по умолчанию localhost)
LEGALDESK_OLLAMA_BASE_URL=http://localhost:11434

# Модель для обнаружения ПДн
LEGALDESK_OLLAMA_MODEL=llama3.1:8b

# Путь к моделям Ollama (Windows)
LEGALDESK_OLLAMA_MODELS_PATH=C:\Users\Администратор\.ollama\models

# Таймаут запроса к Ollama (секунды)
LEGALDESK_OLLAMA_TIMEOUT=60.0

# Использовать LLM для детекции (true/false)
# При false работает только regex (быстрее, но менее точно)
LEGALDESK_USE_LLM=true
